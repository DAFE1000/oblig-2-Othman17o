   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt \n",
    "\n",
    "def g(x):\n",
    "    return np.arctan(x) - 4 / (1+x**2)\n",
    "def derivert_g(x):\n",
    "    return 1 / (1+x**2) + 8*x / ((1+x**2)**2)\n",
    "\n",
    "x = 2\n",
    "for i in range(1,10):\n",
    "    x = x - g(x) / derivert_g(x)\n",
    "    print(f'x = {x:.4f}')"
   ]
